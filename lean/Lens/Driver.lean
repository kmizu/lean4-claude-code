import Lens.Translate
import Lens.Equations

/-!
# Per-declaration driver and closure loop
-/

namespace Lens

open Lean Meta

def translateName (n : Name) : ExtractM Unit := do
  modify fun s => { s with current := n, fresh := 0 }
  match (← getEnv).find? n with
  | none => recordError n "closure" "unknown constant"
  | some ci =>
    try
      match ci with
      | .thmInfo _ => markSeen n .skipped
      | .ctorInfo cv =>
        require cv.induct
        markSeen n .skipped
      | .inductInfo iv =>
        if ← isPropFormer iv.type then
          markSeen n .skipped
        else
          transInductive iv
          markSeen n .emitted
      | .defnInfo dv =>
        if ← Meta.isProp dv.type then
          markSeen n .skipped
        else if dv.safety != .safe then
          recordError n "closure" "`partial`/`unsafe` definitions are not extractable"
        else
          match ← getEqnsFor? n with
          | some eqns => transDefViaEqns dv eqns
          | none => transDef dv
          markSeen n .emitted
      | .opaqueInfo _ => recordError n "closure" "opaque constants are not extractable"
      | .axiomInfo _ => recordError n "closure" "axioms are not extractable"
      | _ => recordError n "closure" "unsupported declaration kind"
    catch ex =>
      recordError n "translate" (← ex.toMessageData.toString)

partial def drain : ExtractM Unit := do
  let s ← get
  if s.queue.isEmpty then return
  let n := s.queue[0]!
  modify fun st => { st with queue := st.queue.eraseIdx! 0 }
  translateName n
  drain

/-- Run extraction from `roots`; all-or-nothing per the fail-loud policy. -/
def extractModule (roots : List Name) (cfg : Config) :
    MetaM (Except (Array LensError) MS.SModule) := do
  let go : ExtractM Unit := do
    roots.forM require
    drain
  let (_, s) ← go.run { cfg }
  if s.errors.isEmpty then
    let types := (s.out.filter (·.isType)).qsort byName
    let defs := (s.out.filter (!·.isType)).qsort byName
    return .ok {
      pkg := cfg.pkg
      header := ["GENERATED by Lens from the Shallot Lean sources. DO NOT EDIT.",
                 "Regenerate with `make regen`; drift is caught by `make check-drift`."]
      decls := types.toList ++ defs.toList
    }
  else
    return .error s.errors
where
  byName (a b : MS.SDecl) : Bool := decide (a.name < b.name)

end Lens
